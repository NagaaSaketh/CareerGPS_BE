# CareerGPS Backend — Environment Configuration
# Copy this file to .env and fill in your values
# DO NOT commit .env to git

# =============================================================================
# ANTHROPIC (required)
# Powers the 6-agent AI pipeline via Claude
# Get from https://console.anthropic.com → API Keys
# =============================================================================
ANTHROPIC_API_KEY=sk-ant-your-key-here

# =============================================================================
# SUPABASE (required)
# Get from Supabase Dashboard → Settings → API
# =============================================================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_ANON_KEY=your-anon-key-here

# =============================================================================
# CORS (required in production)
# Set to your Vercel frontend URL
# Multiple origins: https://your-app.vercel.app,https://your-preview.vercel.app
# =============================================================================
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# =============================================================================
# JOB SCRAPING (optional)
# Set ENABLE_JD_SCRAPING=false on Render free tier to prevent OOM crashes
# App will serve realistic mock jobs instead
# =============================================================================
ENABLE_JD_SCRAPING=false

# =============================================================================
# DEBUG
# =============================================================================
DEBUG=false
