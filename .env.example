# CareerGPS Environment Configuration
# Copy this file to .env and fill in your values
# DO NOT commit real keys to git

# =============================================================================
# SUPABASE (required for production)
# Get these from your Supabase project dashboard → Settings → API
# =============================================================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_ANON_KEY=your-anon-key-here

# =============================================================================
# OPENAI (optional - system works without LLM calls for core functionality)
# =============================================================================
OPENAI_API_KEY=sk-your-key-here

# =============================================================================
# GITHUB API (for real repo analysis - optional but recommended)
# =============================================================================
GITHUB_TOKEN=ghp_your_token_here

# =============================================================================
# JOB SCRAPER CONFIGURATION
# =============================================================================
# Enable/disable live JD scraping (default: true)
# Set to false on low-memory deployments (e.g., Render free tier)
ENABLE_JD_SCRAPING=true

# Maximum jobs to scrape per source per query
JOBS_PER_SOURCE=5

# Cache TTL in hours for scraped market data
MARKET_CACHE_TTL_HOURS=24

# =============================================================================
# CORS (comma-separated list of allowed origins)
# Add your Vercel frontend URL here for production
# =============================================================================
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# =============================================================================
# DEBUG
# =============================================================================
DEBUG=false
